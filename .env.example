# OpenRouter API key — get one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_key_here

# Slack Incoming Webhook URL — set up at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Child configuration
# Birthdate in YYYY-MM-DD format — age is computed automatically
CHILD_BIRTHDATE=2025-09-15
CHILD_NAME=Baby

# OpenRouter model (cost-effective default)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
